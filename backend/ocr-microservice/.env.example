# Configuración del Microservicio OCR ChefChek

# Configuración de la aplicación
APP_NAME=ChefChek OCR Microservice
APP_VERSION=1.0.0
DEBUG=True

# Configuración del servidor
HOST=0.0.0.0
PORT=8000

# Configuración de OCR
OCR_LANGUAGE=es
OCR_USE_GPU=False
OCR_CONFIDENCE_THRESHOLD=0.7

# Configuración de procesamiento de imágenes
IMAGE_DPI=300
IMAGE_MAX_SIZE=10485760
IMAGE_ALLOWED_FORMATS=jpg,jpeg,png,pdf

# Configuración de LLM (opcional para Fase 2)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3

# Configuración de Redis (opcional para Fase 3)
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=ocr_jobs

# Configuración de logging
LOG_LEVEL=INFO
LOG_FILE=logs/ocr_service.log