# Database
DATABASE_URL="postgresql://chefchek:chefchek_password_change_in_production@postgres:5432/chefchek?schema=public"

# Redis (optional, used for caching)
REDIS_URL="redis://redis:6379"

# JWT Authentication
JWT_SECRET="CHANGE_THIS_TO_SECURE_32_CHAR_SECRET_MINIMUM_IN_PRODUCTION"
JWT_EXPIRES_IN="24h"

# Application
NODE_ENV="production"
PORT="3001"
API_PREFIX="/api"

# CORS (frontend domains)
ALLOWED_ORIGINS="https://chefchek.com,https://app.chefchek.com,https://api.chefchek.com"

# Optional: Telegram Bot
TELEGRAM_BOT_TOKEN=""

# Optional: OCR Service
OCR_API_KEY=""

# Optional: Error Tracking (Sentry)
SENTRY_DSN=""

# Optional: Email Configuration
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Optional: File Upload Limits
MAX_FILE_SIZE_MB="10"

# Production Settings
LOG_LEVEL="error"
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="60000"