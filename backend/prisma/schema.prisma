  category KnowledgeCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author   User                  @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  updater  User                  @relation("ArticleUpdater", fields: [updatedBy], references: [id], onDelete: Restrict)
  versions KnowledgeVersion[]
  tags     KnowledgeArticleTag[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([slug])
  @@index([status])
  @@index([categoryId])
  @@map("knowledge_articles")
}

model KnowledgeVersion {
  id         String   @id @default(cuid())
  articleId  String
  version    Int
  content    Json
  changeNote String?
  createdBy  String
  createdAt  DateTime @default(now())

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author  User             @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([articleId])
  @@index([version])
  @@map("knowledge_versions")
}

model KnowledgeTag {
