  supplierId   String
  averagePrice Float
  recordDate   DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([tenantId])
  @@index([recordDate])
  @@index([supplierId, recordDate])
  @@map("supplier_price_histories")
}

// Albaranes — Documentos de entrada persistente
model Albaran {
  id              String        @id @default(cuid())
  tenantId        String
  supplierId      String? // Proveedor asociado (null si no hay match)
  internalNumber  String // Número interno auto-generado por tenant
  albaranNumber   String? // Número del albarán del proveedor
  date            DateTime      @default(now())
  base            Float         @default(0) // Base imponible
  vatTotal        Float         @default(0) // Total IVA
  total           Float         @default(0) // Total con IVA
  grossAmount     Float         @default(0) // Total bruto (antes de IVA)
  vatBreakdown    Json? // Desglose de IVA por tipo: [{rate, base, amount}]
  status          AlbaranStatus @default(PENDIENTE)
  originalFileUrl String? // URL del archivo original subido
  ocrConfidence   Float         @default(0) // 0-1 confianza global OCR
  ocrRawData      Json? // Respuesta cruda del OCR para re-procesado
  warehouseId     String? // Almacén seleccionado para la entrada de stock
  purchaseOrderId String? // Pedido de compra que este albarán recibe (conciliación, módulo Compras)
  notes           String?
  applyDiscountToCost Boolean @default(false) // Opt-in: al confirmar, el coste/escandallos usa el precio neto (con descuento) en vez del bruto
  createdBy       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier        Supplier?             @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  warehouse       Warehouse?            @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  purchaseOrder   PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  lines           AlbaranLine[]
  priceHistory    ProductPriceHistory[]
  invoices        Invoice[]
  priceDeviations PriceDeviation[]

  @@unique([tenantId, internalNumber])
  @@index([tenantId])
  @@index([supplierId])
  @@index([status])
  @@index([date])
  @@index([warehouseId])
  @@index([purchaseOrderId])
  @@map("albaranes")
}

model AlbaranLine {
  id               String          @id @default(cuid())
  albaranId        String
  articleNumber    String? // Código de artículo del proveedor
  lot              String? // Lote (opcional)
  description      String
  quantity         Float
  unit             String          @default("ud")
  unitPrice        Float
  vatPercent       Float           @default(10)
  priceWithVat     Float? // Precio unidad con IVA (unit_price × (1 + vat%))
  totalPrice       Float? // Importe neto de la línea leído del papel (sin IVA, con descuento si lo hay). El OCR lo trae pero qty×precio puede no cuadrar cuando hay dto.
  lineAmount       Float // Cantidad × precio unidad bruto (sin IVA, sin descuento)
  matchStatus      LineMatchStatus @default(NUEVO)
  lineStatus       LineStatus      @default(PENDIENTE)
  matchedProductId String? // FK a Product si hay match
  confidence       Float           @default(0) // 0-1 confianza del match
  lineOrder        Int             @default(0) // Posición en el documento origen; createdAt no sirve de desempate (mismo now() en creación anidada)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  albaran        Albaran  @relation(fields: [albaranId], references: [id], onDelete: Cascade)
  matchedProduct Product? @relation(fields: [matchedProductId], references: [id], onDelete: SetNull)
  lotRecord      Lot? // Registro de trazabilidad creado a partir de esta línea (campo escalar `lot` de arriba es el nº de lote en crudo)

  @@index([albaranId])
  @@index([matchedProductId])
  @@index([matchStatus])
  @@map("albaran_lines")
}

// Alias aprendido: texto crudo con el que un proveedor concreto describe un
// artículo (abreviaturas, orden de palabras distinto...) → producto real.
// Se escribe cuando el usuario confirma manualmente el match de una línea
// (matchLine) y se consulta antes del match exacto/fuzzy en futuros albaranes
// del mismo proveedor, para no repetir la misma corrección cada vez.
model SupplierProductAlias {
  id                    String   @id @default(cuid())
  tenantId              String
  supplierId            String
  normalizedDescription String // texto de línea normalizado (minúsculas, sin acentos/espacios extra)
  productId             String
  confirmedBy           String? // userId que confirmó el match origen del alias
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, supplierId, normalizedDescription])
  @@index([productId])
  @@map("supplier_product_aliases")
}

model Lot {
  id            String    @id @default(cuid())
  tenantId      String
  productId     String
  albaranLineId String?   @unique // línea de origen; 1 lote por línea recibida
  lotNumber     String
  quantity      Float // cantidad recibida en este lote (no se decrementa en este plan)
  warehouseId   String?
  supplierId    String?
  receivedAt    DateTime  @default(now())
  expiryDate    DateTime? // reservado para captura futura (OCR no lo extrae hoy)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  albaranLine AlbaranLine? @relation(fields: [albaranLineId], references: [id], onDelete: SetNull)
  warehouse   Warehouse?   @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  supplier    Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  stockMovements StockMovement[]

  @@index([tenantId])
  @@index([productId])
  @@index([lotNumber])
  @@map("lots")
}

// Unidades de medida configurables por tenant
model UnitOfMeasure {
  id        String   @id @default(cuid())
  tenantId  String
  name      String // "Kilogramo", "Litro", "Unidad", "Docena", "Caja"
  symbol    String // "kg", "L", "und", "doc", "caja"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, symbol])
  @@index([tenantId])
  @@map("units_of_measure")
}

// Historial de precios por producto (con/sin proveedor)
model ProductPriceHistory {
  id            String   @id @default(cuid())
  tenantId      String
  productId     String
  supplierId    String? // Proveedor asociado al cambio de precio
  albaranId     String? // Albarán que originó el cambio
  previousPrice    Float // Precio anterior
  newPrice         Float // Precio nuevo
  previousUnitSize Float? // unitSize vigente al registrar previousPrice; null en filas legacy
  newUnitSize      Float? // unitSize vigente al registrar newPrice; null en filas legacy
  recordedAt       DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  albaran  Albaran?  @relation(fields: [albaranId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([productId])
  @@index([supplierId])
  @@index([recordedAt])
  @@index([productId, recordedAt])
  @@map("product_price_histories")
}

// Catálogo global de alérgenos (UE 1169/2011). No es por tenant: los 14
// alérgenos oficiales son universales. El `id` coincide con el código UE
// (1-14) para que el `Int[]` de Product/Recipe/Menu y el enum AllergenEU
// sigan resolviendo sin migrar datos. Los alérgenos creados por el usuario
// toman id = max(id)+1 (>=15).
model Allergen {
  id          Int      @id
  name        String
  nameEu1169  String?
  description String?
  icon        String?
  color       String?
  severity    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("allergens")
}

// Copias de seguridad integradas (export/import). tenantId es nullable para
// copias globales (SUPERADMIN); kind separa EXPORT (snapshot) de RESTORE (job
// de restauración). Los auto-backups previos a un restore usan
// type=AUTO_PRE_RESTORE y son visibles en el historial como anchor de rollback.
model Backup {
  id             String       @id @default(cuid())
  tenantId       String?
  scope          BackupScope  @default(TENANT)
  status         BackupStatus @default(PENDING)
  kind           BackupKind
  type           BackupType   @default(MANUAL)
  format         String       @default("json")
  filename       String?
  fileSizeBytes  BigInt?
  rowCount       Int?
  checksum       String?
  schemaVersion  Int          @default(1)
  sourceBackupId String?
  notes          String?
  errorMessage   String?      @db.Text
  createdBy      String?
  createdAt      DateTime     @default(now())
  completedAt    DateTime?

  @@index([tenantId, kind, createdAt])
  @@index([scope, createdAt])
  @@map("backups")
}

enum BackupScope {
  TENANT
  GLOBAL
}

enum BackupStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum BackupKind {
  EXPORT
  RESTORE
}

enum BackupType {
  MANUAL
  AUTO_PRE_RESTORE
  AUTO_SCHEDULED
}

// ══════════════════════════════════════════════════════════════
// Módulo Compras (pedidos a proveedores) + multi-local
// ══════════════════════════════════════════════════════════════

// Local del grupo de restauración (multi-local). Cada tenant tiene al menos
// un local por defecto (backfill en la migración add_compras_foundations).
model Location {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  isDefault Boolean   @default(false)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouses            Warehouse[]
  purchaseOrders        PurchaseOrder[]
  purchaseLists         PurchaseList[]
  offerLocationSettings OfferLocationSetting[]
  purchaseSchedules     PurchaseSchedule[]

  @@index([tenantId])
  @@map("locations")
}

enum PurchaseOrderStatus {
  BORRADOR
  PENDIENTE_ENVIO
  ENVIADO
  RECIBIDO_PARCIAL
  RECIBIDO
  CANCELADO
}

// Pedido de compra a un proveedor
model PurchaseOrder {
  id          String              @id @default(cuid())
  tenantId    String
  orderNumber String // Secuencial por tenant: PED-1, PED-2... (calcular con $queryRaw MAX sobre TODAS las filas, incluidas soft-deleted)
  supplierId  String
  locationId  String?
  status      PurchaseOrderStatus @default(BORRADOR)
  notes       String?

  // Envío al proveedor
  sentAt  DateTime?
  sentVia String? // EMAIL, WHATSAPP, PHONE, WEB
  sentBy  String? // userId que registró el envío

  expectedTotal Float  @default(0) // Suma de expectedPrice × quantity de las líneas
  receivedTotal Float? // Suma real tras conciliar con albarán

  createdBy String? // userId
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier        Supplier             @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  location        Location?            @relation(fields: [locationId], references: [id], onDelete: SetNull)
  lines           PurchaseOrderLine[]
  events          PurchaseOrderEvent[]
  albaranes       Albaran[]
  invoices        Invoice[]
  priceDeviations PriceDeviation[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, status])
  @@index([tenantId, supplierId])
  @@index([tenantId, locationId])
  @@map("purchase_orders")
}

// Línea de pedido: cantidad pedida vs recibida (conciliación con albarán)
model PurchaseOrderLine {
  id               String  @id @default(cuid())
  orderId          String
  productId        String
  quantity         Float
  unit             String? // Unidad de la cantidad (formato de compra del producto)
  expectedPrice    Float? // Precio unitario esperado (oferta activa al crear el pedido)
  receivedQuantity Float? // Rellenado al conciliar con el albarán
  receivedPrice    Float? // Precio unitario real del albarán
  lineNotes        String?
  sortOrder        Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("purchase_order_lines")
}

// Lista de compra (checklist de artículos por proveedor). Base de los pedidos
// manuales y de las programaciones (Sprint 6).
model PurchaseList {
  id         String    @id @default(cuid())
  tenantId   String
  supplierId String
  locationId String?
  name       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier  Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  location  Location?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  items     PurchaseListItem[]
  schedules PurchaseSchedule[]

  @@index([tenantId, supplierId])
  @@map("purchase_lists")
}

model PurchaseListItem {
  id              String   @id @default(cuid())
  listId          String
  productId       String
  defaultQuantity Float    @default(1)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  list    PurchaseList @relation(fields: [listId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([listId, productId])
  @@index([productId])
  @@map("purchase_list_items")
}

// Programación de pedidos: genera un pedido BORRADOR + notificación en el
// día/hora configurados. NUNCA envía nada automáticamente (decisión de
// producto). Zona horaria fija Europe/Madrid (single-región, sin necesidad
// de configurarla por tenant por ahora).
model PurchaseSchedule {
  id         String    @id @default(cuid())
  tenantId   String
  supplierId String
  listId     String
  locationId String?
  daysOfWeek Int[] // 0=domingo … 6=sábado (Date.getDay() de JS)
  timeOfDay  String // "HH:mm" 24h, hora local Europe/Madrid
  enabled    Boolean   @default(true)
  lastRunAt  DateTime? // último tick que generó un pedido (claim de idempotencia)
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  list     PurchaseList @relation(fields: [listId], references: [id], onDelete: Cascade)
  location Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([tenantId, enabled])
  @@map("purchase_schedules")
}

// Auditoría del pedido: creación, cambios de estado, envíos por canal
model PurchaseOrderEvent {
  id      String  @id @default(cuid())
  orderId String
  type    String // CREATED, STATUS_CHANGED, SENT, SCHEDULED_GENERATION...
  channel String? // EMAIL, WHATSAPP, PHONE, WEB (solo eventos de envío)
  userId  String?
  payload Json?

  createdAt DateTime @default(now())

  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("purchase_order_events")
}

enum PriceDeviationStatus {
  PENDIENTE
  RECLAMADA
  RESUELTA
}

// Desviación detectada entre el precio pactado de una oferta y el precio
// realmente recibido (albarán o catálogo importado). Histórico gestionable,
// no se recalcula: cada desviación es la fotografía del momento en que se
// detectó.
model PriceDeviation {
  id               String               @id @default(cuid())
  tenantId         String
  offerId          String
  albaranId        String?
  purchaseOrderId  String?
  agreedPrice      Float
  receivedPrice    Float
  deviationPercent Float
  status           PriceDeviationStatus @default(PENDIENTE)
  note             String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  offer         ProductSupplierOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  albaran       Albaran?             @relation(fields: [albaranId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([offerId])
  @@index([albaranId])
  @@index([purchaseOrderId])
  @@map("price_deviations")
}

enum CatalogImportStatus {
  PENDIENTE
  APLICADO
  DESCARTADO
}

enum CatalogLineStatus {
  PROPUESTA
  ACEPTADA
  RECHAZADA
}

// Importación de tarifa/catálogo de un proveedor (foto/PDF) vía IA: líneas
// propuestas que exigen revisión humana antes de tocar ninguna oferta real.
model CatalogImport {
  id         String              @id @default(cuid())
  tenantId   String
  supplierId String
  fileUrl    String?
  aiModel    String?
  status     CatalogImportStatus @default(PENDIENTE)
  createdBy  String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  deletedAt  DateTime?

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  lines    CatalogImportLine[]

  @@index([tenantId, supplierId])
  @@map("catalog_imports")
}

model CatalogImportLine {
  id               String            @id @default(cuid())
  catalogImportId  String
  rawName          String // Descripción extraída del catálogo
  articleNumber    String?
  purchaseFormat   String?
  unitPrice        Float
  matchedProductId String?
  matchStatus      LineMatchStatus   @default(NUEVO)
  lineStatus       CatalogLineStatus @default(PROPUESTA)
  confidence       Float             @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  catalogImport  CatalogImport @relation(fields: [catalogImportId], references: [id], onDelete: Cascade)
  matchedProduct Product?      @relation(fields: [matchedProductId], references: [id], onDelete: SetNull)

  @@index([catalogImportId])
  @@index([matchedProductId])
  @@map("catalog_import_lines")
}
