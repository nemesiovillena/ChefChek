generator client {
  provider      = "prisma-client-js"
  // The image is built in the `oven/bun` stage (Debian 12 / OpenSSL 3.0) but the
  // runtime is `node:20-bullseye-slim` (Debian 11 / OpenSSL 1.1). Without an
  // explicit target, Prisma generates only the builder's native engine, which the
  // runtime cannot load. Generate for both x86_64 (Dokploy/Hostinger VPS, amd64)
  // and arm64 (local Docker Desktop on Apple Silicon) container runtimes.
  binaryTargets = ["native", "debian-openssl-1.1.x", "linux-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core - Multi-tenancy
model Tenant {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  domain    String?   @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Datos de contacto del cliente (gestión superadmin)
  contactName       String?
  contactPosition   String?
  contactPhone      String?
  contactEmail      String?
  addressStreet     String?
  addressCity       String?
  addressPostalCode String?
  cifNif            String?

  users                  User[]
  products               Product[]
  recipes                Recipe[]
  menus                  Menu[]
  invoices               Invoice[]
  temperatureControls    TemperatureControl[]
  cleaningPlans          CleaningPlan[]
  pestControls           PestControl[]
  goodsReceptions        GoodsReception[]
  alerts                 Alert[]
  staffMembers           StaffMember[]
  workBatches            WorkBatch[]
  taskAssignments        TaskAssignment[]
  productionAlerts       ProductionAlert[]
  productionOrders       ProductionOrder[]
  miseEnPlaceSheets      MiseEnPlaceSheet[]
  warehouses             Warehouse[]
  orders                 Order[]
  appccControls          AppccControl[]
  documents              Document[]
  telegramBots           TelegramBot[]
  telegramUsers          TelegramUser[]
  suppliers              Supplier[]
  supplierPriceHistories SupplierPriceHistory[]
  albaranes              Albaran[]
  unitsOfMeasure         UnitOfMeasure[]
  productPriceHistories  ProductPriceHistory[]
  productSupplierOffers  ProductSupplierOffer[]
  configurations         Configuration[]
  categories             Category[]
  stocks                 Stock[]
  documentTemplates      DocumentTemplate[]
  inventories            Inventory[]
  knowledgeCategories    KnowledgeCategory[]
  knowledgeArticles      KnowledgeArticle[]
  knowledgeTags          KnowledgeTag[]
  auditLogs              AuditLog[]
  digitalMenuConfigs     DigitalMenuConfig[]
  dashboardMetrics       DashboardMetric[]
  dashboardAlerts        DashboardAlert[]
  qrcodes                QRCode[]
  locations              Location[]
  purchaseOrders         PurchaseOrder[]
  purchaseLists          PurchaseList[]
  priceDeviations        PriceDeviation[]
  catalogImports         CatalogImport[]
  offerLocationSettings  OfferLocationSetting[]
  purchaseSchedules      PurchaseSchedule[]
  lots                   Lot[]
  supplierProductAliases SupplierProductAlias[]

  @@map("tenants")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String?
  email        String
  passwordHash String
  name         String
  role         UserRole  @default(USER)
  isActive     Boolean   @default(true)
  avatarUrl    String?
  street       String?
  city         String?
  phone        String?
  whatsapp     String?
  payrollEmail String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // tenantId is null for SUPERADMIN users (no tenant scope)
  tenant            Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions          Session[]
  knowledgeArticles KnowledgeArticle[]
  articleVersions   KnowledgeVersion[]
  updatedArticles   KnowledgeArticle[] @relation("ArticleUpdater")
  telegramUsers     TelegramUser[]
  AuditLog          AuditLog[]

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Escandallos - Core Fase 1
model Product {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  description String?
  categoryId  String?
  supplierId  String?

  // Unidad de referencia (simplificado: UC + referencia)
  purchaseFormat    String @default("") // "Garrafa 5L", "Saco 25kg", "Caja 6und"
  referenceUnit     String @default("kg") // "kg", "L", "und" — unidad base para precio y recetas
  unitsPerFormat    Int    @default(1) // Unidades en el formato de compra (ej: 6 botellas por caja)
  referenceUnitSize Float  @default(1) // Tamaño de cada unidad en referenceUnits (ej: 1.5L por botella)
  unitSize          Float  @default(1) // Auto-calculado: unitsPerFormat × referenceUnitSize

  // Precios
  purchasePrice         Float
  previousPurchasePrice Float @default(0)
  netPrice              Float
  profitMargin          Float @default(0)
  discountPercentage    Float @default(0) // Descuento informativo del proveedor sobre purchasePrice (no recalcula precios)

  // Rendimiento
  wastePercentage Float @default(0)
  yieldFactor     Float @default(1.0)

  // Prueba de rendimiento (Peso Bruto/Neto → deriva yieldFactor/wastePercentage) + ración
  grossWeight   Float? // Peso Bruto (kg) de la prueba de rendimiento
  netWeight     Float? // Peso Neto (kg) tras mermar
  portionWeight Float? // Peso de una ración (g), para el coste de ración

  // Alérgenos (array de IDs)
  allergens Int[]

  // Campos extendidos
  iva           Float   @default(10)
  qr            String?
  barcode       String?
  brand         String?
  hideAllergens Boolean @default(false)
  imageUrl      String?
  lot           String?

  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  manualPurchaseDate DateTime? // Fecha de compra editada manualmente en el listado

  tenant             Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category           Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supplier           Supplier?              @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  recipeIngredients  RecipeIngredient[]
  stockMovements     StockMovement[]
  stocks             Stock[]
  purchaseFormats    PurchaseFormat[]
  nutritionalInfo    NutritionalInfo?
  albaranLines       AlbaranLine[]
  priceHistory       ProductPriceHistory[]
  supplierOffers     ProductSupplierOffer[]
  purchaseOrderLines PurchaseOrderLine[]
  purchaseListItems  PurchaseListItem[]
  catalogImportLines CatalogImportLine[]
  lots               Lot[]
  supplierAliases    SupplierProductAlias[]

  @@index([tenantId])
  @@index([name])
  @@index([categoryId])
  @@index([barcode])
  @@map("products")
}

model PurchaseFormat {
  id        String   @id @default(cuid())
  productId String
  name      String
  format    String
  price     Float
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("purchase_formats")
}

// Oferta de un proveedor concreto para un artículo. Un Product puede tener
// varias ofertas (mismo ingrediente, distintos proveedores/precios); la
// marcada `isPreferred` es la única que sincroniza los campos planos de
// Product (purchasePrice/netPrice/supplierId/formato), que siguen siendo la
// fuente que lee el motor de costeo de recetas sin cambios.
// El @@unique de Prisma se omite a propósito: la unicidad real (máx. 1
// preferente por producto, máx. 1 oferta activa por proveedor) se aplica con
// índices únicos parciales creados a mano en la migración (Prisma no soporta
// índices parciales de forma declarativa).
model ProductSupplierOffer {
  id         String @id @default(cuid())
  tenantId   String
  productId  String
  supplierId String

  purchaseFormat    String @default("")
  referenceUnit     String @default("kg")
  unitsPerFormat    Int    @default(1)
  referenceUnitSize Float  @default(1)
  unitSize          Float  @default(1)

  purchasePrice         Float
  previousPurchasePrice Float @default(0)
  netPrice              Float
  profitMargin          Float @default(0)

  // Precio pactado con el proveedor (control de desviaciones, módulo Compras)
  agreedPrice Float? // Precio acordado; null = sin pacto, comportamiento actual intacto
  agreedAt    DateTime? // Se estampa automáticamente al fijar/cambiar agreedPrice
  agreedUntil DateTime? // Vigencia opcional; pasada esta fecha no se evalúa

  isPreferred Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product          Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier         Supplier               @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  deviations       PriceDeviation[]
  locationSettings OfferLocationSetting[]

  @@index([tenantId])
  @@index([productId])
  @@index([supplierId])
  @@map("product_supplier_offers")
}

// Activa/desactiva una oferta concreta para un local (multi-local, módulo
// Compras): sin fila = sigue el criterio general (oferta preferente).
model OfferLocationSetting {
  id         String   @id @default(cuid())
  tenantId   String
  offerId    String
  locationId String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  offer    ProductSupplierOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  location Location             @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([offerId, locationId])
  @@index([tenantId])
  @@index([locationId])
  @@map("offer_location_settings")
}

model NutritionalInfo {
  id                 String @id @default(cuid())
  productId          String @unique
  energyKj           Float?
  energyKcal         Float?
  fat                Float?
  saturatedFat       Float?
  transFat           Float?
  monounsaturatedFat Float?
  polyunsaturatedFat Float?
  omega3             Float?
  cholesterol        Float?
  carbohydrates      Float?
  sugars             Float?
  protein            Float?
  salt               Float?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("nutritional_info")
}

model Recipe {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  description String?
  elaboration String? // Structured steps JSON or TipTap JSON
  notes       String? // Additional notes for the recipe
  imageUrl    String? // Recipe image path
  sourceUrl   String? // Original recipe URL

  // Costeo
  totalCost        Float @default(0)
  totalCostPerUnit Float @default(0)

  // Pricing (PVP con IVA manual; sin IVA derivado a 1,10; coste objetivo siempre el global de Configuración)
  sellingPriceWithVat Float?
  sellingPrice        Float?

  // Rendimiento
  portions    Int   @default(1)
  portionSize Float @default(1)

  // Versionado
  version       Int     @default(1)
  parentVersion String?

  isActive  Boolean   @default(true)
  isPublic  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingredients       RecipeIngredient[]
  subRecipes        RecipeSubRecipe[]   @relation("ParentRecipe")
  subRecipesAsChild RecipeSubRecipe[]   @relation("SubRecipe")
  menuItems         MenuItem[]
  menuSectionItems  MenuSectionItem[]
  allergens         Int[]               @default([])
  categories        RecipeCategory[]
  translations      RecipeTranslation[]

  @@index([tenantId])
  @@index([name])
  @@map("recipes")
}

model RecipeIngredient {
  id        String @id @default(cuid())
  recipeId  String
  productId String
  quantity  Float
  unit      String

  recipe  Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([recipeId, productId])
  @@map("recipe_ingredients")
}

model RecipeSubRecipe {
  id             String @id @default(cuid())
  parentRecipeId String
  subRecipeId    String
  quantity       Float
  unit           String

  parentRecipe Recipe @relation("ParentRecipe", fields: [parentRecipeId], references: [id], onDelete: Cascade)
  subRecipe    Recipe @relation("SubRecipe", fields: [subRecipeId], references: [id], onDelete: Cascade)

  @@unique([parentRecipeId, subRecipeId])
  @@map("recipe_sub_recipes")
}

model RecipeTranslation {
  id          String   @id @default(cuid())
  recipeId    String
  language    String
  name        String
  description String?
  elaboration String?
  createdAt   DateTime @default(now())

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, language])
  @@map("recipe_translations")
}

// Múltiples Categorías por Receta (Muchos-a-Muchos)
model RecipeCategory {
  id         String   @id @default(cuid())
  recipeId   String
  categoryId String
  createdAt  DateTime @default(now())

  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([recipeId, categoryId])
  @@map("recipe_categories")
}

enum UserRole {
  SUPERADMIN
  OWNER
  ADMIN
  USER
  VIEWER
}

enum CategoryContext {
  articles
  recipes
}

enum AlbaranStatus {
  PENDIENTE
  REVISADO
  CONFIRMADO
  ARCHIVADO
}

enum LineMatchStatus {
  NUEVO
  MATCH_ALTO
  MATCH_DUDOSO
}

enum LineStatus {
  PENDIENTE
  CONFIRMADO
  RECHAZADO
}

// Sprint Tracker - Sprint 16
model Sprint {
  id             String    @id @default(cuid())
  name           String
  description    String?
  type           String // DEVELOPMENT, REFACTORING, DOCUMENTATION, TESTING, INFRASTRUCTURE
  status         String // NOT_STARTED, IN_PROGRESS, BLOCKED, COMPLETED, CANCELLED
  startDate      DateTime
  endDate        DateTime
  tenantId       String
  projectId      String?
  objectives     Json?
  teamMembers    Json?
  notes          String?
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  progress       Float     @default(0)
  totalTasks     Int       @default(0)
  completedTasks Int       @default(0)

  tasks      Task[]
  teamMember TeamMember[]

  @@map("sprints")
}

model Task {
  id             String    @id @default(cuid())
  title          String
  description    String
  sprintId       String
  status         String // TODO, IN_PROGRESS, IN_REVIEW, COMPLETED, CANCELLED, BLOCKED
  priority       String // CRITICAL, HIGH, MEDIUM, LOW
  dueDate        DateTime?
  tags           Json?
  estimatedHours Float?
  assignedTo     String?
  dependsOn      String[]
  blockedBy      Json?
  notes          String?
  tenantId       String
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  sprint          Sprint           @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  assignedMember  TeamMember?      @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  notifications   Notification[]
  taskAssignments TaskAssignment[]

  @@map("tasks")
}

model TeamMember {
  id             String   @id @default(cuid())
  name           String
  role           String
  email          String
  avatar         String?
  isActive       Boolean  @default(true)
  availableHours Float    @default(40)
  assignedTasks  Int      @default(0)
  completedTasks Int      @default(0)
  tenantId       String
  createdAt      DateTime @default(now())

  tasks   Task[]
  sprints Sprint[]

  @@map("team_members")
}

model Notification {
  id          String   @id @default(cuid())
  type        String
  title       String
  message     String
  taskId      String?
  sprintId    String?
  recipientId String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  priority    String // LOW, MEDIUM, HIGH, URGENT
  metadata    Json?

  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// Menú y Cartas
model Menu {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  slug        String?
  qrCodeId    String?
  startDate   DateTime?
  endDate     DateTime?
  portions    Int       @default(1)
  totalCost   Float     @default(0)
  totalPrice  Float     @default(0)
  totalMargin Float     @default(0)
  isActive    Boolean   @default(true)
  allergens   Int[]     @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items              MenuItem[]
  translations       MenuTranslation[]
  analytics          MenuAnalytics[]
  sections           MenuSection[]
  digitalMenuConfigs DigitalMenuConfig[]

  @@index([tenantId])
  @@index([slug])
  @@map("menus")
}

model MenuTranslation {
  id                   String   @id @default(cuid())
  menuId               String
  language             String
  title                String
  name                 String?
  description          String?
  branding             Json?
  sectionsTranslations Json?
  createdAt            DateTime @default(now())

  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@map("menu_translations")
}

model MenuAnalytics {
  id       String   @id @default(cuid())
  menuId   String
  type     String // view, interaction
  viewedAt DateTime
  metadata Json?

  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@map("menu_analytics")
}

model MenuSection {
  id          String  @id @default(cuid())
  menuId      String
  name        String
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  menu  Menu              @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items MenuSectionItem[]

  @@map("menu_sections")
}

model MenuSectionItem {
  id          String  @id @default(cuid())
  sectionId   String
  recipeId    String
  order       Int     @default(0)
  price       Float   @default(0)
  cost        Float   @default(0)
  margin      Float   @default(0)
  isAvailable Boolean @default(true)

  section MenuSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  recipe  Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("menu_section_items")
}

model MenuItem {
  id          String  @id @default(cuid())
  menuId      String
  recipeId    String
  category    String
  sortOrder   Int     @default(0)
  price       Float   @default(0)
  cost        Float   @default(0)
  margin      Float   @default(0)
  isAvailable Boolean @default(true)
  isActive    Boolean @default(true)

  menu   Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([menuId, recipeId])
  @@map("menu_items")
}

// Facturación
model Invoice {
  id              String    @id @default(cuid())
  tenantId        String
  invoiceNumber   String
  supplier        String
  totalAmount     Float
  status          String
  issuedAt        DateTime
  dueDate         DateTime?
  albaranId       String? // Albarán de recepción asociado (registro mínimo, módulo Compras)
  purchaseOrderId String? // Pedido de compra asociado
  fileUrl         String? // Archivo de la factura (opcional)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  albaran       Albaran?       @relation(fields: [albaranId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  @@index([albaranId])
  @@index([purchaseOrderId])
  @@map("invoices")
}

// Almacenes
model Warehouse {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  location   String? // Descripción libre de ubicación (texto); NO confundir con locationId (multi-local)
  locationId String? // Local (entidad Location) al que pertenece el almacén
  capacity   Float?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  locationRef Location?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  movements   StockMovement[]
  stocks      Stock[]
  inventories Inventory[]
  albaranes   Albaran[]
  lots        Lot[]

  @@index([locationId])
  @@map("warehouses")
}

// Movimientos de Stock
model StockMovement {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String?
  lotId       String?
  type        String // ENTRANCE, EXIT, ADJUSTMENT
  quantity    Float
  unit        String
  reason      String?
  createdAt   DateTime @default(now())

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  lot       Lot?       @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@map("stock_movements")
}

// Órdenes
model Order {
  id          String    @id @default(cuid())
  tenantId    String
  orderNumber String
  supplier    String
  totalAmount Float
  status      String
  orderedAt   DateTime
  receivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("orders")
}

// APPCC - Temperature Control
model TemperatureControl {
  id                String   @id @default(cuid())
  tenantId          String
  type              String // FRIDGE, FREEZER, STORAGE, etc.
  location          String
  targetTemperature Float?
  tolerance         Float
  unit              String // CELSIUS, FAHRENHEIT
  description       String?
  responsible       String?
  isActive          Boolean  @default(true)
  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant       Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  measurements TemperatureMeasurement[]

  @@map("temperature_controls")
}

model TemperatureMeasurement {
  id          String   @id @default(cuid())
  controlId   String
  temperature Float
  status      String // OK, WARNING, CRITICAL
  notes       String?
  withinRange Boolean  @default(true)
  measuredBy  String
  recordedBy  String?
  measuredAt  DateTime @default(now())
  recordedAt  DateTime @default(now())

  control TemperatureControl @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@map("temperature_measurements")
}

// APPCC - Cleaning Plan
model CleaningPlan {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  area            String
  planType        String // DAILY, WEEKLY, MONTHLY
  frequency       String
  responsible     String[]
  durationMinutes Int?
  isActive        Boolean  @default(true)
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks  CleaningTask[]

  @@map("cleaning_plans")
}

model CleaningTask {
  id            String    @id @default(cuid())
  planId        String
  taskName      String
  taskType      String?
  description   String?
  area          String?
  products      String[]
  estimatedTime Int?
  responsible   String[]
  completed     Boolean   @default(false)
  completedBy   String?
  verifiedBy    String?
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  plan CleaningPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("cleaning_tasks")
}

// APPCC - Pest Control
model PestControl {
  id          String    @id @default(cuid())
  tenantId    String
  controlDate DateTime
