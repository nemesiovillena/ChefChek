}

// Proveedores
model Supplier {
  id                  String    @id @default(cuid())
  tenantId            String
  name                String
  cifNif              String? // CIF/NIF para auto-matching con OCR
  address             String? // Dirección del proveedor
  contactPerson       String?
  email               String?
  phone               String?
  whatsapp            String?
  website             String?
  sanitaryRegistry    String? // Nº registro sanitario RGSA
  iban                String? // IBAN para pagos
  paymentTerms        String? // Condiciones de pago en texto libre, p.ej. "30 días fecha factura"
  notes               String?   @db.Text // Notas internas sobre el proveedor
  averageDeliveryTime Int       @default(3) // días
  reliabilityScore    Float     @default(85) // 0-100
  priceTier           String    @default("MEDIUM") // LOW, MEDIUM, HIGH
  preferredStatus     String    @default("ALTERNATIVE") // PREFERRED, ALTERNATIVE, EXCLUDED
  orderMethods        String[]  @default(["EMAIL"]) // EMAIL, PHONE, WEB, WHATSAPP
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  ocrLayoutHints Json? // Patrones de layout del proveedor para mejorar OCR

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products              Product[]
  priceHistory          SupplierPriceHistory[]
  productPriceHistories ProductPriceHistory[]
  albaranes             Albaran[]
  supplierOffers        ProductSupplierOffer[]
  purchaseOrders        PurchaseOrder[]
  purchaseLists         PurchaseList[]
  catalogImports        CatalogImport[]
  purchaseSchedules     PurchaseSchedule[]
  lots                  Lot[]
  productAliases        SupplierProductAlias[]

  @@index([tenantId])
  @@index([name])
  @@index([cifNif])
  @@map("suppliers")
}

// Stock Management
model Stock {
  id            String   @id @default(cuid())
  tenantId      String
  productId     String
  warehouseId   String?
  quantity      Float    @default(0) // Stock actual
  reservedStock Float    @default(0) // Stock reservado para pedidos
  minimumStock  Float    @default(0) // Stock mínimo
  maximumStock  Float? // Stock máximo
  reorderLevel  Float    @default(0) // Nivel de reposición
  lastUpdated   DateTime @default(now())
  notes         String?

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@index([tenantId])
  @@index([productId])
  @@index([warehouseId])
  @@index([quantity])
  @@map("stocks")
}

// Inventarios Físicos
model Inventory {
  id          String    @id @default(cuid())
