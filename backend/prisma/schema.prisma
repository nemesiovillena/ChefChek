// Documentos
model Document {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  type         String // TECHNICAL_SHEET, RECIPE_CARD, INSTRUCTION, OTHER, RECEIPT, INVOICE, ORDER_CONFIRMATION, PRODUCT_CATALOG, DELIVERY_NOTE
  category     String
  recipeId     String?
  templateId   String?
  version      Int      @default(1)
  createdBy    String
  fileSize     Int
  fileFormat   String // PDF, DOCX
  url          String
  fileUrl      String? // URL para OCR/AI
  fileName     String? // Nombre del archivo original
  fileId       String? // ID del archivo en Telegram/S3
  source       String? // telegram, upload, api
  sourceUserId String? // ID del usuario que subió
  status       String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  ocrData      Json? // Texto extraído por OCR
  aiData       Json? // Datos estructurados extraídos por AI
  errorMessage String? // Error si el procesamiento falló
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  telegramBot       TelegramBot?       @relation(fields: [telegramBotId], references: [id], onDelete: SetNull)
