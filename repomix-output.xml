        type: 'CLEANING',
        title: 'Recordatorio de Limpieza - Limpieza Diaria Cocina',
        message: '1 tarea pendiente del plan "Limpieza Diaria Cocina"',
        status: 'OPEN',
        createdAt: new Date(),
