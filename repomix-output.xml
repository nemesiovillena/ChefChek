      expect(prisma.user.findMany).toHaveBeenCalledWith({
        where: { tenantId: "tenant-id" },
        skip: 0,
        take: 20,
        orderBy: { createdAt: "desc" },
        select: {
          id: true,
          email: true,
          name: true,
