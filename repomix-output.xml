# Agregar las siguientes entradas:

# ==============================
# BACKUPS CHEFCHEK
# ==============================

# Backup diario (cada día a las 02:00)
0 2 * * * /path/to/chefchek/backend/scripts/backup.sh --type daily >> /var/log/chefchek-backup.log 2>&1

# Backup semanal (domingos a las 03:00)
