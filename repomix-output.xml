      });

      await expect(
        service.sendOrder("tenant-123", "order-1", { sentBy: "user-1" }),
      ).rejects.toThrow(BadRequestException);
    });
  });

  describe("getOrdersHistory", () => {
    it("should return orders history", async () => {
      const tenantId = "tenant-123";

      const mockOrders = [
        {
          id: "order-1",
