                <Plus className="mr-2 h-4 w-4" />
                Nueva Carta
              </Button>
            </div>

            {isCreateModalOpen && (
              <Card className="p-6">
                <CardHeader>
                  <CardTitle>Crear Nueva Carta Digital</CardTitle>
