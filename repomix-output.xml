async function handleProcessingError(
  chatId: number,
  file: IngestedFile,
  error: Error
): Promise<void> {
  const errorMessages = {
    [IngestionErrorType.FILE_TOO_LARGE]: 'El archivo es demasiado grande (máximo 10MB)',
    [IngestionErrorType.UNSUPPORTED_FILE_TYPE]: 'Formato de archivo no soportado',
