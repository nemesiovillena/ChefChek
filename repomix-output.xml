          orderNumber: "ORD-001",
          status: OrderStatus.SENT,
          supplier: { name: "Supplier A" },
          items: [],
          createdAt: new Date(),
        },
        {
          id: "order-2",
          tenantId,
          supplierId: "supplier-2",
          orderNumber: "ORD-002",
          status: OrderStatus.APPROVED,
          supplier: { name: "Supplier B" },
          items: [],
