generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core - Multi-tenancy
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  domain    String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  products      Product[]
  recipes       Recipe[]
  menus         Menu[]
  invoices      Invoice[]
  temperatureControls TemperatureControl[]
  cleaningPlans CleaningPlan[]
  pestControls   PestControl[]
  goodsReceptions GoodsReception[]
  alerts        Alert[]
  staffMembers   StaffMember[]
  workBatches   WorkBatch[]
  taskAssignments TaskAssignment[]
  productionAlerts ProductionAlert[]
  productionOrders ProductionOrder[]
  miseEnPlaceSheets MiseEnPlaceSheet[]
  warehouses    Warehouse[]
  orders        Order[]
  appccControls AppccControl[]
  documents     Document[]
  telegramBots  TelegramBot[]
  telegramUsers TelegramUser[]
  suppliers     Supplier[]
  configurations Configuration[]
  categories    Category[]
  stocks        Stock[]
  documentTemplates DocumentTemplate[]
  inventories   Inventory[]
  knowledgeCategories KnowledgeCategory[]
  knowledgeArticles KnowledgeArticle[]
  knowledgeTags KnowledgeTag[]
  digitalMenuConfigs DigitalMenuConfig[]
