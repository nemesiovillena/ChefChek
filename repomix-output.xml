      mockPrismaService.recipe.findFirst.mockResolvedValue({
        id: recipeId,
        ingredients: [{ product: { allergens: [1, 3] } }],
        subRecipes: [],
      });
      mockPrismaService.recipe.update.mockResolvedValue({});

      const result = await service.detectAllergenConflicts(
