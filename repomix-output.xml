  describe("getOrderStatus", () => {
    it("should return order status summary", async () => {
      mockOrdersService.getAutomatedOrder.mockResolvedValue({
        id: "order-1",
        status: "SENT",
        urgency: "HIGH",
        scheduledDelivery: new Date("2026-06-06"),
        sentAt: new Date("2026-06-04"),
        receivedAt: null,
