                      </Select>
                    </div>
                    <div className="grid grid-cols-2 gap-4">
                      <div>
                        <Label>Fecha Inicio</Label>
                        <Input
                          type="date"
                          value={newSprint.startDate}
                          onChange={(e) => setNewSprint({ ...newSprint, startDate: e.target.value })}
                        />
                      </div>
                      <div>
                        <Label>Fecha Fin</Label>
                        <Input
                          type="date"
