      await expect(
        service.update("non-existent", updateUserDto, "tenant-id"),
      ).rejects.toThrow(NotFoundException);
      await expect(
        service.update("non-existent", updateUserDto, "tenant-id"),
      ).rejects.toThrow("User not found");
