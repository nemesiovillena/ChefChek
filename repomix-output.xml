                      {sprintProgress.atRisk && (
                        <Badge variant="destructive">⚠ Riesgo de retraso</Badge>
                      )}
                    </div>
                  </div>

                  <div>
                    <h3 className="text-lg font-semibold mb-4">Desglose de Tareas</h3>
                    <div className="grid grid-cols-4 gap-4">
                      <Card>
                        <CardContent className="pt-6">
                          <p className="text-sm text-muted-foreground">Completadas</p>
                          <p className="text-2xl font-bold text-green-600">{sprintProgress.completedTasks}</p>
                        </CardContent>
                      </Card>
                      <Card>
                        <CardContent className="pt-6">
                          <p className="text-sm text-muted-foreground">En Progreso</p>
                          <p className="text-2xl font-bold text-blue-600">{sprintProgress.inProgressTasks}</p>
                        </CardContent>
                      </Card>
                      <Card>
                        <CardContent className="pt-6">
                          <p className="text-sm text-muted-foreground">Bloqueadas</p>
                          <p className="text-2xl font-bold text-red-600">{sprintProgress.blockedTasks}</p>
                        </CardContent>
                      </Card>
                      <Card>
                        <CardContent className="pt-6">
                          <p className="text-sm text-muted-foreground">Pendientes</p>
                          <p className="text-2xl font-bold text-gray-600">{sprintProgress.remainingTasks - sprintProgress.inProgressTasks - sprintProgress.blockedTasks}</p>
                        </CardContent>
                      </Card>
                    </div>
                  </div>

                  {sprintProgress.estimatedCompletionDate && (
                    <div>
                      <h3 className="text-lg font-semibold mb-4">Estimación</h3>
                      <Card>
                        <CardContent className="pt-6">
                          <p className="text-sm text-muted-foreground">Fecha estimada de completación</p>
                          <p className="text-xl font-semibold">{new Date(sprintProgress.estimatedCompletionDate).toLocaleDateString()}</p>
                        </CardContent>
                      </Card>
                    </div>
                  )}
                </div>
              ) : (
                <Alert>
                  <AlertTitle>Sprint no seleccionado</AlertTitle>
                  <AlertDescription>Selecciona un sprint para ver su progreso.</AlertDescription>
                </Alert>
              )}
            </CardContent>
          </Card>
        )}

        {currentStep === 4 && (
          <Card>
            <CardHeader className="flex flex-row items-center justify-between">
              <div>
                <CardTitle>Notificaciones</CardTitle>
                <CardDescription>{unreadCount} notificaciones sin leer</CardDescription>
              </div>
              <Button onClick={handleMarkAllAsRead} variant="outline">Marcar todas como leídas</Button>
            </CardHeader>
            <CardContent>
              <ScrollArea className="h-[600px]">
                <div className="space-y-4">
                  {notifications.map(notif => (
                    <Card key={notif.id} className={!notif.read ? 'bg-accent/50' : ''}>
                      <CardContent className="pt-6">
                        <div className="flex items-start justify-between">
                          <div className="flex-1">
                            <div className="flex items-center gap-2 mb-2">
                              <Badge variant={notif.priority === 'URGENT' ? 'destructive' : notif.priority === 'HIGH' ? 'default' : 'secondary'}>
                                {notif.priority}
                              </Badge>
                              <Badge variant={notif.read ? 'secondary' : 'default'}>
                                {notif.read ? 'Leída' : 'Nueva'}
                              </Badge>
                            </div>
                            <h3 className="text-lg font-semibold mb-2">{notif.title}</h3>
                            <p className="text-sm text-muted-foreground">{notif.message}</p>
                            <p className="text-xs text-muted-foreground mt-2">
                              {new Date(notif.createdAt).toLocaleString()}
                            </p>
                          </div>
                          {!notif.read && (
                            <Button
                              size="sm"
                              variant="outline"
                              onClick={() => handleMarkAsRead(notif.id)}
                            >
                              Marcar como leída
                            </Button>
                          )}
                        </div>
                      </CardContent>
                    </Card>
                  ))}
                </div>
              </ScrollArea>
            </CardContent>
          </Card>
        )}
      </div>
    </div>
  );
}
