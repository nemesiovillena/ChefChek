}
```

### 4. Recepción de Mercancías

```typescript
interface GoodsReception {
  id: string;
  proveedorId: string;
  fecha: Date;
  temperaturaAlRecepcion: number;
  temperaturaAceptable: number;
  lote: string;
  caducidad: Date;
  albaran: string;
