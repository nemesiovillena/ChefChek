      mockPrismaService.menu.findUnique.mockResolvedValue(mockMenu);

      await service.update(tenantId, menuId, dtoWithTranslations);

      expect(mockPrismaService.menuTranslation.deleteMany).toHaveBeenCalledWith(
        { where: { menuId } },
