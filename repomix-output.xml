      prisma.user.count.mockResolvedValue(50);

      await service.findAll("tenant-id", 3, 10);

      expect(prisma.user.findMany).toHaveBeenCalledWith(
        expect.objectContaining({
          skip: 20,
          take: 10,
        }),
