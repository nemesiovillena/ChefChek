        id: "user-1",
        role: "VIEWER",
        isActive: true,
      });

      const result = await service.checkEndpointPermission(
        "user-1",
        "/api/v1/products/create",
        "POST",
      );

      expect(result.hasAccess).toBe(false);
    });
  });

  describe("getPermissionsByRole", () => {
    it("should return permissions grouped by resource", async () => {
