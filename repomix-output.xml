                </DialogContent>
              </Dialog>
            </CardHeader>
            <CardContent>
              <div className="grid gap-4">
                {sprints.map(sprint => (
                  <Card key={sprint.id} className="cursor-pointer hover:bg-accent/50 transition-colors"
