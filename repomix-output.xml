// Factor de complejidad
const complexityFactors = {
  SIMPLE: 1.0,
  MODERATE: 1.5,
  COMPLEX: 2.0,
  ADVANCED: 2.5,
};

// Cálculo de tiempo estimado
estimatedTime = (
  (basePreparationTime * quantity * complexityFactor) +
  (baseCookingTime * quantity * complexityFactor) +
  (basePlatingTime * quantity)
);
