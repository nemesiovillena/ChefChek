  ES = 'es',  // Español
  EN = 'en',  // Inglés
  FR = 'fr',  // Francés
  DE = 'de',  // Alemán
  IT = 'it',  // Italiano
  PT = 'pt',  // Portugués
  CA = 'ca',  // Catalán
  EU = 'eu',  // Euskera
  GL = 'gl',  // Gallego
}
