                    />
                  </div>
                  <div>
                    <Label>Menú asociado</Label>
                    <Select value={selectedMenuId} onValueChange={(value) => setSelectedMenuId(value || '')}>
                      <SelectTrigger>
                        <SelectValue placeholder="Selecciona un menú" />
                      </SelectTrigger>
                      <SelectContent>
                        {(menus || []).map((menu) => (
                          <SelectItem key={menu.id} value={menu.id}>
                            {menu.name}
                          </SelectItem>
