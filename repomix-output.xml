      });

      const result = await service.hasAllPermissions("user-1", [
        "products:create",
        "products:read",
      ]);

      expect(result).toBe(true);
    });

    it("should return false if user missing one permission", async () => {
      mockPrismaService.user.findUnique.mockResolvedValue({
        id: "user-1",
        role: "VIEWER",
        isActive: true,
      });

      const result = await service.hasAllPermissions("user-1", [
