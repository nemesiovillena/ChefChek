# Alerta si tamaño es < 80% de promedio
#!/bin/bash
BACKUP_SIZE=$(stat -f%z chefchek_daily_20250603_020000.dump.gz)
AVG_SIZE=$(ls -l /var/backups/chefchek/daily/*.dump.gz | awk '{sum+=$5} END {print sum/NR}')
